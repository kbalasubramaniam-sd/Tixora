				{
					"name": "Login — Wrong Password (401)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"sarah.ahmad@tixora.ae\",\n  \"password\": \"WrongPassword\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/login"
					}
				},
				{
					"name": "GET /me — Current User",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/api/auth/me"
					}
				},
				{
					"name": "GET /me — No Token (401)",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/api/auth/me"
					}
				}
			]
		},
		{
			"name": "Products",
			"item": [
				{
					"name": "GET /products — All Products (no auth)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Returns 4 products', function() {",
									"    var json = pm.response.json();",
									"    pm.expect(json.length).to.eql(4);",
									"});",
									"pm.test('Has correct product codes', function() {",
									"    var json = pm.response.json();",
									"    var codes = json.map(p => p.code);",
									"    pm.expect(codes).to.include('RBT');",
									"    pm.expect(codes).to.include('RHN');",
									"    pm.expect(codes).to.include('WTQ');",
									"    pm.expect(codes).to.include('MLM');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/api/products"
					}
				}
			]
		},
		{
			"name": "Partners",
			"item": [
				{
					"name": "GET /partners — All Partners (auth required)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Returns 3 partners', function() {",
									"    var json = pm.response.json();",
									"    pm.expect(json.length).to.eql(3);",
									"});",
									"pm.test('Each partner has products', function() {",
									"    var json = pm.response.json();",
									"    json.forEach(p => {",
									"        pm.expect(p.products.length).to.be.above(0);",
									"    });",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": "{{baseUrl}}/api/partners"
					}
				},
				{
					"name": "GET /partners — No Token (401)",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/api/partners"
					}
				}
			]
		}
	]
}
