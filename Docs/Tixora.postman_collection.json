{
	"info": {
		"_postman_id": "tixora-api-v1",
		"name": "Tixora API — MVP 1",
		"description": "Tixora Strategic Partner Management Portal API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "https://localhost:7255",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login — Requester (Sarah)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('token', json.token);",
									"    pm.test('Token received', function() {",
									"        pm.expect(json.token).to.be.a('string');",
									"    });",
									"    pm.test('User returned', function() {",
									"        pm.expect(json.user.fullName).to.eql('Sarah Ahmad');",
									"        pm.expect(json.user.role).to.eql('PartnershipTeam');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"sarah.ahmad@tixora.ae\",\n  \"password\": \"Password1!\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/login"
					}
				},
				{
					"name": "Login — ProductTeam (Hannoun)",
					"event": [
